---
import Icon from './Icon.astro';
import { cases } from '../data/cases';

const [caseA, caseB] = cases;
---
<section class="relative overflow-hidden pt-28 md:pt-36 pb-16 md:pb-24">
  <!-- Ледь помітна карбонова фактура -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2228%22 height=%2228%22 viewBox=%220 0 28 28%22><path d=%22M0 14h28M14 0v28%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"
    aria-hidden="true"
  ></div>
  <!-- м'яке оранжеве світіння -->
  <div
    class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[720px] h-[420px] rounded-full blur-[120px] opacity-20"
    style="background: radial-gradient(circle, #E86A00, transparent 70%);"
    aria-hidden="true"
  ></div>
  <!-- другий, менший шар світла — кінематографічна глибина за карткою кейсу -->
  <div
    class="pointer-events-none absolute top-1/3 right-0 hidden lg:block w-[420px] h-[420px] rounded-full blur-[100px] opacity-[0.12]"
    style="background: radial-gradient(circle, #F2801E, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="container-site relative grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-10 items-center">
    <!-- Ліва колонка -->
    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-sm text-muted">
        <span class="w-2 h-2 rounded-full bg-success"></span>
        Харків · працюємо по всій Україні
      </span>

      <h1 class="mt-6 text-[1.75rem] leading-[1.1] sm:text-5xl lg:text-[3.4rem] font-extrabold">
        Від ідеї до гранту <span class="text-accent-gradient">«Власна справа»</span> — <span class="whitespace-nowrap">за 2–3 дні</span> і без бюрократичного стресу
      </h1>

      <p class="mt-6 text-lg text-muted max-w-xl">
        До 500 000 грн безповоротної допомоги від держави для Харківщини. Юрист готує план за формою Дії за 2–3 дні: цифри, які сходяться і проходять перевірку банку.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="/#lead" class="btn btn-primary" data-analytics="click_cta_hero">
          Безкоштовний експрес-аудит ідеї
        </a>
        <a href="/case-bpla" class="btn btn-ghost">
          Подивитись приклад плану
        </a>
      </div>

      <a href="/#quiz" class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-hover" data-analytics="click_calc_hero">
        Розрахувати суму гранту <Icon name="arrow-right" size={16} />
      </a>

      <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm text-muted">
        <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> Чесна оцінка шансів до оплати</li>
        <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> Прозорі ціни</li>
        <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> 2 раунди правок включено</li>
      </ul>
    </div>

    <!-- Права колонка: приклади слайдів реальних кейсів (переворот) -->
    <div class="reveal hidden lg:block">
      <button
        type="button"
        data-hero-flip
        aria-label="Показати інший приклад бізнес-плану"
        class="hero-flip block w-full text-left rotate-[0.5deg] cursor-pointer"
      >
        <div class="hero-flip-inner">
          <div class="hero-flip-face glass-card rounded-[20px] p-3 shadow-xl">
            <img
              src={caseA.cover}
              alt={`Приклад бізнес-плану за формою Дії: ${caseA.title}`}
              width="1280" height="800" fetchpriority="high" decoding="async"
              class="w-full rounded-2xl block"
            />
          </div>
          <div class="hero-flip-face hero-flip-back glass-card rounded-[20px] p-3 shadow-xl">
            <img
              src={caseB.cover}
              alt={`Приклад бізнес-плану за формою Дії: ${caseB.title}`}
              width="1280" height="800" decoding="async"
              class="w-full rounded-2xl block"
            />
          </div>
        </div>
      </button>
    </div>
  </div>
</section>

<style>
  .hero-flip {
    perspective: 1600px;
  }
  .hero-flip-inner {
    position: relative;
    width: 100%;
    aspect-ratio: 1280 / 800;
    transform-style: preserve-3d;
    transition: transform 0.9s cubic-bezier(0.4, 0.2, 0.2, 1);
  }
  .hero-flip.is-flipped .hero-flip-inner {
    transform: rotateY(180deg);
  }
  .hero-flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .hero-flip-back {
    transform: rotateY(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-flip-inner { transition: none; }
  }
</style>

<script>
  const flipEls = document.querySelectorAll<HTMLElement>('[data-hero-flip]');
  flipEls.forEach((el) => {
    let auto: ReturnType<typeof setInterval> | null = null;
    const toggle = () => el.classList.toggle('is-flipped');
    const startAuto = () => {
      if (auto) clearInterval(auto);
      auto = setInterval(toggle, 6000);
    };
    el.addEventListener('click', () => {
      toggle();
      startAuto(); // клік скидає таймер, щоб не перевернулось одразу після ручного кліку
    });
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduceMotion) startAuto();
  });
</script>
