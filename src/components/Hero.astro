---
import Icon from './Icon.astro';
---
<section class="relative overflow-hidden pt-28 md:pt-36 pb-16 md:pb-24">
  <!-- Ледь помітна карбонова фактура -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2228%22 height=%2228%22 viewBox=%220 0 28 28%22><path d=%22M0 14h28M14 0v28%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"
    aria-hidden="true"
  ></div>
  <!-- м'яке оранжеве світіння -->
  <div
    class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[720px] h-[420px] rounded-full blur-[120px] opacity-20"
    style="background: radial-gradient(circle, #D97E3D, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="container-site relative grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-10 items-center">
    <!-- Ліва колонка -->
    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-sm text-muted">
        <span class="w-2 h-2 rounded-full bg-success"></span>
        Харків · працюємо по всій Україні
      </span>

      <h1 class="mt-6 text-[2.1rem] leading-[1.08] sm:text-5xl lg:text-[3.4rem] font-extrabold">
        Від ідеї до гранту <span class="text-accent-gradient">«Власна справа»</span> — за 2–3 дні і без бюрократичного стресу
      </h1>

      <p class="mt-6 text-lg text-muted max-w-xl">
        До 500 000 грн безповоротної допомоги від держави для Харківщини. Юрист готує план за формою Дії за 2–3 дні: цифри, які сходяться і проходять перевірку банку.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="/#lead" class="btn btn-primary" data-analytics="click_cta_hero">
          Безкоштовний експрес-аудит ідеї
        </a>
        <a href="/case-bpla" class="btn btn-ghost">
          Подивитись приклад плану
        </a>
      </div>

      <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm text-muted">
        <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> Чесна оцінка шансів до оплати</li>
        <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> Прозорі ціни</li>
        <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> 2 раунди правок включено</li>
      </ul>
    </div>

    <!-- Права колонка: скляний макет першої сторінки плану -->
    <div class="reveal hidden lg:block" aria-hidden="true">
      <div class="glass-card rounded-[20px] p-5 shadow-xl rotate-[0.5deg]">
        <!-- Заглушка макета документа. Власник замінить скрином демо-кейсу. -->
        <div class="rounded-2xl bg-raised border border-border p-6">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-accent/15 grid place-items-center text-accent">
                <Icon name="file-text" size={18} />
              </span>
              <div>
                <div class="text-xs text-muted">Бізнес-план · форма Дії</div>
                <div class="text-sm font-semibold">Власна справа 2026</div>
              </div>
            </div>
            <span class="text-xs rounded-md bg-success/15 text-success px-2 py-1">Перевірено</span>
          </div>

          <div class="mt-5 space-y-2.5">
            <div class="h-2.5 rounded bg-border/80 w-[92%]"></div>
            <div class="h-2.5 rounded bg-border/60 w-[78%]"></div>
            <div class="h-2.5 rounded bg-border/60 w-[85%]"></div>
          </div>

          <div class="mt-5 grid grid-cols-3 gap-3">
            <div class="rounded-xl bg-surface border border-border p-3">
              <div class="text-xs text-muted">Грант</div>
              <div class="text-accent font-display font-extrabold text-lg mt-1">500К</div>
            </div>
            <div class="rounded-xl bg-surface border border-border p-3">
              <div class="text-xs text-muted">Строк</div>
              <div class="font-display font-extrabold text-lg mt-1">2–3 дні</div>
            </div>
            <div class="rounded-xl bg-surface border border-border p-3">
              <div class="text-xs text-muted">Правки</div>
              <div class="font-display font-extrabold text-lg mt-1">×2</div>
            </div>
          </div>

          <div class="mt-5 flex items-end gap-1.5 h-20">
            {[38, 52, 46, 64, 72, 88].map((h) => (
              <div class="flex-1 rounded-t bg-gradient-to-t from-accent/30 to-accent" style={`height:${h}%`}></div>
            ))}
          </div>
          <div class="mt-2 text-xs text-muted">Фінмодель · 36 місяців</div>
        </div>
      </div>
    </div>
  </div>
</section>
