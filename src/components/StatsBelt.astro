---
const stats = [
  { value: 'до 500 000 ₴', label: 'грант для Харківщини' },
  { value: '~70%', label: 'відмов через слабкий бізнес-план' },
  { value: '2–3 дні', label: 'строк підготовки' },
  { value: '34 000+', label: 'підприємців по Україні вже отримали грант за програмою' },
];
---
<section class="py-12 md:py-16 border-y border-border/70 bg-surface/40">
  <div class="container-site grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-8">
    {stats.map((s) => (
      <div class="reveal text-center lg:text-left">
        <div class="font-display font-extrabold text-2xl sm:text-3xl lg:text-[2rem] text-accent">{s.value}</div>
        <div class="mt-1.5 text-sm text-muted max-w-[16rem] mx-auto lg:mx-0">{s.label}</div>
      </div>
    ))}
  </div>
</section>
