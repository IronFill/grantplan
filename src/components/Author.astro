---
import Icon from './Icon.astro';

const bullets = [
  { icon: 'award', text: 'Багаторічна юридична практика' },
  { icon: 'scale', text: 'Кримінальне, економічне та корпоративне право' },
  { icon: 'shield-check', text: 'Консалтинг із кібербезпеки' },
  { icon: 'handshake', text: 'Волонтерство: працевлаштування ВПО та ветеранів' },
];
---
<section class="py-16 md:py-24 scroll-mt-20">
  <div class="container-site grid lg:grid-cols-[0.8fr_1.2fr] gap-10 lg:gap-14 items-center">
    <!-- Фото юриста -->
    <div class="reveal">
      <img
        src="/images/team/lawyer-v3.webp"
        alt="Юрист, який готує бізнес-плани під грант «Власна справа»"
        width="1000" height="1250" loading="lazy" decoding="async"
        class="aspect-[4/5] w-full object-cover rounded-[20px] border border-border"
      />
    </div>

    <div class="reveal">
      <h2 class="text-3xl sm:text-4xl">Хто готує ваш план</h2>
      <p class="mt-5 text-muted text-lg leading-relaxed">
        Практикуючий юрист із багаторічним досвідом — експерт у кримінальному, економічному та корпоративному праві, а також у консалтингу з кібербезпеки. Щодня працюю з клієнтами, знаю, як читає бізнес-план банківський оцінювач, і готую пакет документів, до якого не буває питань. Веду кожен проєкт особисто, без передачі підрядникам. Беру активну участь у громадському житті Харкова та займаюся волонтерством: допомагаю ветеранам, їхнім родинам і внутрішньо переміщеним особам із працевлаштуванням та відкриттям власної справи.
      </p>
      <ul class="mt-7 space-y-3">
        {bullets.map((b) => (
          <li class="flex items-center gap-3">
            <span class="inline-grid place-items-center w-10 h-10 rounded-xl bg-accent/10 text-accent shrink-0">
              <Icon name={b.icon} size={20} />
            </span>
            <span class="font-medium">{b.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
