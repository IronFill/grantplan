---
import Icon from './Icon.astro';

const bullets = [
  { icon: 'scale', text: 'Юридична освіта і практика' },
  { icon: 'map-pin', text: 'Спеціалізація: Харківщина та прифронтові ліміти' },
];
---
<section class="py-16 md:py-24 scroll-mt-20">
  <div class="container-site grid lg:grid-cols-[0.8fr_1.2fr] gap-10 lg:gap-14 items-center">
    <!-- Фото юриста -->
    <div class="reveal">
      <img
        src="/images/team/lawyer.webp"
        alt="Юрист, який готує бізнес-плани під грант «Власна справа»"
        width="1000" height="1250" loading="lazy" decoding="async"
        class="aspect-[4/5] w-full object-cover rounded-[20px] border border-border"
      />
    </div>

    <div class="reveal">
      <h2 class="text-3xl sm:text-4xl">Хто готує ваш план</h2>
      <p class="mt-5 text-muted text-lg leading-relaxed">
        Я юрист, щодня працюю з документами, розрахунками та вимогами держорганів. Знаю, як читає план банківський оцінювач, і складаю документи, до яких не буває питань. Працюю особисто, без передачі підрядникам. Окремий фокус — ветерани та їхні родини: розумію специфіку і допомагаю пройти шлях без бюрократичного стресу.
      </p>
      <ul class="mt-7 space-y-3">
        {bullets.map((b) => (
          <li class="flex items-center gap-3">
            <span class="inline-grid place-items-center w-10 h-10 rounded-xl bg-accent/10 text-accent shrink-0">
              <Icon name={b.icon} size={20} />
            </span>
            <span class="font-medium">{b.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
