---
import Icon from './Icon.astro';
import { site } from '../data/site';
---
<section id="booking" class="py-16 md:py-24 scroll-mt-20">
  <div class="container-site">
    <div class="reveal max-w-2xl">
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-sm text-muted">
        <Icon name="clock" size={16} class="text-accent" /> Запис на консультацію
      </span>
      <h2 class="mt-5 text-3xl sm:text-4xl">Оберіть зручний день і час</h2>
      <p class="mt-4 text-muted text-lg">
        Безкоштовна консультація до 20 хвилин: чесно скажемо, чи проходить ваша ідея під умови програми. Оберіть дату й час — заявка одразу надійде нам, і ми підтвердимо запис у Telegram або телефоном.
      </p>
    </div>

    <div class="reveal mt-8 rounded-[20px] bg-surface border border-border p-5 md:p-8">
      <div id="bk-form-wrap" class="grid lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Календар -->
        <div>
          <div class="flex items-center justify-between mb-4">
            <button type="button" data-bk-prev aria-label="Попередній місяць"
              class="inline-grid place-items-center w-10 h-10 rounded-xl border border-border text-muted hover:text-ink hover:border-accent transition-colors disabled:opacity-30 disabled:pointer-events-none">
              <Icon name="chevron-down" size={18} class="rotate-90" />
            </button>
            <div data-bk-month class="font-display font-semibold text-lg capitalize">—</div>
            <button type="button" data-bk-next aria-label="Наступний місяць"
              class="inline-grid place-items-center w-10 h-10 rounded-xl border border-border text-muted hover:text-ink hover:border-accent transition-colors">
              <Icon name="chevron-down" size={18} class="-rotate-90" />
            </button>
          </div>
          <div class="grid grid-cols-7 gap-1.5 text-center text-xs text-muted mb-2">
            <span>Пн</span><span>Вт</span><span>Ср</span><span>Чт</span><span>Пт</span><span>Сб</span><span>Нд</span>
          </div>
          <div data-bk-days class="grid grid-cols-7 gap-1.5"></div>
          <p class="mt-4 text-xs text-muted flex items-center gap-2">
            <span class="inline-block w-3 h-3 rounded-full bg-accent"></span> обрана дата · неділя — вихідний
          </p>
        </div>

        <!-- Час + контакти -->
        <div class="lg:border-l lg:border-border/70 lg:pl-12">
          <div data-bk-time-empty class="text-muted text-sm py-4">
            Спочатку оберіть день у календарі ←
          </div>

          <div data-bk-time-wrap hidden>
            <div class="text-sm font-medium mb-3">
              Вільний час на <span data-bk-picked-date class="text-accent">—</span>
            </div>
            <div data-bk-slots class="grid grid-cols-3 sm:grid-cols-4 gap-2 mb-6"></div>
          </div>

          <form id="bk-form" novalidate hidden>
            <div class="hidden" aria-hidden="true">
              <label>Не заповнюйте це поле<input type="text" name="hp_gp_2026" tabindex="-1" autocomplete="off" /></label>
            </div>
            <input type="hidden" name="source" value="booking" />
            <input type="hidden" name="date" data-bk-date value="" />
            <input type="hidden" name="time" data-bk-time value="" />

            <div class="space-y-4">
              <div>
                <label for="bk-name" class="block text-sm font-medium mb-1.5">Ім’я <span class="text-accent">*</span></label>
                <input id="bk-name" name="name" type="text" required autocomplete="name"
                  class="w-full rounded-xl bg-raised border border-border px-4 py-3 text-base placeholder:text-muted/70 focus:border-accent outline-none"
                  placeholder="Ваше ім’я" />
              </div>
              <div>
                <label for="bk-phone" class="block text-sm font-medium mb-1.5">Телефон <span class="text-accent">*</span></label>
                <input id="bk-phone" name="phone" type="tel" required inputmode="tel" autocomplete="tel"
                  class="w-full rounded-xl bg-raised border border-border px-4 py-3 text-base placeholder:text-muted/70 focus:border-accent outline-none"
                  placeholder="+380 __ ___ __ __" value="+380" />
                <p class="mt-1 text-xs hidden text-accent-hover" data-bk-phone-error>Введіть коректний номер у форматі +380XXXXXXXXX</p>
              </div>
              <fieldset>
                <legend class="block text-sm font-medium mb-2">Зручний месенджер</legend>
                <div class="flex flex-wrap gap-2">
                  {['Telegram', 'Viber', 'Дзвінок'].map((m, i) => (
                    <label class="cursor-pointer">
                      <input type="radio" name="messenger" value={m} class="peer sr-only" checked={i === 0} />
                      <span class="inline-flex items-center rounded-xl border border-border px-4 py-2.5 text-sm peer-checked:border-accent peer-checked:text-accent peer-checked:bg-accent/10 transition-colors">{m}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
              <label class="flex items-start gap-3 text-sm text-muted">
                <input type="checkbox" name="consent" required class="mt-1 w-4 h-4 accent-[#FF8A2A] shrink-0" />
                <span>Погоджуюсь на обробку персональних даних згідно з <a href="/privacy" class="text-accent underline">політикою конфіденційності</a></span>
              </label>
              <button type="submit" class="btn btn-primary w-full" data-bk-submit>
                Записатись на консультацію
              </button>
              <p class="text-sm text-accent-hover text-center hidden" data-bk-error data-tg={site.telegram}></p>
            </div>
          </form>
        </div>
      </div>

      <!-- Екран подяки -->
      <div id="bk-success" class="hidden text-center py-10">
        <span class="inline-grid place-items-center w-16 h-16 rounded-full bg-success/15 text-success mx-auto">
          <Icon name="check-circle" size={32} />
        </span>
        <h3 class="mt-5 text-2xl font-display font-semibold">Вашу заявку підтверджено ✓</h3>
        <p class="mt-2 text-muted">Ви записані на <span data-bk-summary class="text-ink font-medium">—</span>. Заявка вже надійшла нам — звʼяжемося з вами для підтвердження у Telegram або телефоном найближчим часом.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.getElementById('booking');
  if (root) {
    const MONTHS = ['Січень','Лютий','Березень','Квітень','Травень','Червень','Липень','Серпень','Вересень','Жовтень','Листопад','Грудень'];
    const MONTHS_GEN = ['січня','лютого','березня','квітня','травня','червня','липня','серпня','вересня','жовтня','листопада','грудня'];
    const WEEKDAYS = ['неділя','понеділок','вівторок','середа','четвер','пʼятниця','субота'];
    const SLOTS = ['10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00'];

    const monthLabel = root.querySelector('[data-bk-month]') as HTMLElement;
    const daysGrid = root.querySelector('[data-bk-days]') as HTMLElement;
    const prevBtn = root.querySelector('[data-bk-prev]') as HTMLButtonElement;
    const nextBtn = root.querySelector('[data-bk-next]') as HTMLButtonElement;
    const timeEmpty = root.querySelector('[data-bk-time-empty]') as HTMLElement;
    const timeWrap = root.querySelector('[data-bk-time-wrap]') as HTMLElement;
    const slotsGrid = root.querySelector('[data-bk-slots]') as HTMLElement;
    const pickedDateEl = root.querySelector('[data-bk-picked-date]') as HTMLElement;
    const form = root.querySelector('#bk-form') as HTMLFormElement;
    const dateInput = root.querySelector('[data-bk-date]') as HTMLInputElement;
    const timeInput = root.querySelector('[data-bk-time]') as HTMLInputElement;
    const phoneInput = root.querySelector('#bk-phone') as HTMLInputElement;
    const phoneError = root.querySelector('[data-bk-phone-error]') as HTMLElement;
    const submitBtn = root.querySelector('[data-bk-submit]') as HTMLButtonElement;
    const success = root.querySelector('#bk-success') as HTMLElement;
    const formWrap = root.querySelector('#bk-form-wrap') as HTMLElement;
    const summaryEl = root.querySelector('[data-bk-summary]') as HTMLElement;
    const bkError = root.querySelector('[data-bk-error]') as HTMLElement;
    const showBkError = (msg: string) => { if (bkError) { bkError.textContent = msg; bkError.classList.remove('hidden'); } };

    const today = new Date(); today.setHours(0, 0, 0, 0);
    let viewYear = today.getFullYear();
    let viewMonth = today.getMonth();
    let selected: Date | null = null;

    const fmtLong = (d: Date) => `${WEEKDAYS[d.getDay()]}, ${d.getDate()} ${MONTHS_GEN[d.getMonth()]}`;

    function renderCalendar() {
      monthLabel.textContent = `${MONTHS[viewMonth]} ${viewYear}`;
      // не даємо гортати у минулий місяць
      prevBtn.disabled = (viewYear === today.getFullYear() && viewMonth === today.getMonth());

      daysGrid.innerHTML = '';
      const first = new Date(viewYear, viewMonth, 1);
      // зсув під понеділок як перший день тижня (Пн=0 … Нд=6)
      const offset = (first.getDay() + 6) % 7;
      const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

      for (let i = 0; i < offset; i++) {
        daysGrid.appendChild(document.createElement('span'));
      }
      for (let day = 1; day <= daysInMonth; day++) {
        const d = new Date(viewYear, viewMonth, day);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = String(day);
        const isPast = d < today;
        const isSunday = d.getDay() === 0;
        const disabled = isPast || isSunday;
        btn.className = 'aspect-square rounded-xl text-sm font-medium transition-colors ' +
          (disabled
            ? 'text-muted/30 pointer-events-none'
            : 'border border-border hover:border-accent hover:text-accent');
        if (disabled) btn.disabled = true;
        if (selected && d.getTime() === selected.getTime()) {
          btn.className = 'aspect-square rounded-xl text-sm font-semibold bg-accent text-white';
        }
        btn.addEventListener('click', () => pickDate(d));
        daysGrid.appendChild(btn);
      }
    }

    function pickDate(d: Date) {
      selected = d;
      dateInput.value = `${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()} (${WEEKDAYS[d.getDay()]})`;
      timeInput.value = '';
      renderCalendar();
      pickedDateEl.textContent = fmtLong(d);
      // слоти
      slotsGrid.innerHTML = '';
      SLOTS.forEach((t) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.textContent = t;
        b.className = 'rounded-xl border border-border px-2 py-2.5 text-sm hover:border-accent hover:text-accent transition-colors';
        b.addEventListener('click', () => pickTime(t, b));
        slotsGrid.appendChild(b);
      });
      timeEmpty.setAttribute('hidden', '');
      timeWrap.removeAttribute('hidden');
      form.setAttribute('hidden', ''); // форма зʼявиться після вибору часу
    }

    function pickTime(t: string, el: HTMLButtonElement) {
      timeInput.value = t;
      slotsGrid.querySelectorAll('button').forEach((b) => {
        b.className = 'rounded-xl border border-border px-2 py-2.5 text-sm hover:border-accent hover:text-accent transition-colors';
      });
      el.className = 'rounded-xl border border-accent bg-accent/10 text-accent px-2 py-2.5 text-sm font-semibold';
      form.removeAttribute('hidden');
    }

    prevBtn.addEventListener('click', () => {
      viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; }
      renderCalendar();
    });
    nextBtn.addEventListener('click', () => {
      viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; }
      renderCalendar();
    });

    // Маска телефону
    function formatPhone(v: string): string {
      let digits = v.replace(/\D/g, '');
      if (!digits.startsWith('380')) { digits = digits.replace(/^0+/, ''); digits = '380' + digits; }
      return '+' + digits.slice(0, 12);
    }
    phoneInput?.addEventListener('input', () => {
      phoneInput.value = formatPhone(phoneInput.value);
      phoneInput.setSelectionRange(phoneInput.value.length, phoneInput.value.length);
    });
    const validPhone = (v: string) => /^\+380\d{9}$/.test(v);

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = (form.elements.namedItem('hp_gp_2026') as HTMLInputElement)?.value;
      if (hp) return;
      bkError?.classList.add('hidden');
      if (!dateInput.value || !timeInput.value) { showBkError('Оберіть дату й час.'); return; }
      const bkName = (form.elements.namedItem('name') as HTMLInputElement)?.value.trim();
      if (!bkName) { showBkError('Вкажіть, будь ласка, ваше імʼя.'); (form.elements.namedItem('name') as HTMLInputElement)?.focus(); return; }
      if (!validPhone(phoneInput.value)) {
        phoneError?.classList.remove('hidden');
        phoneInput?.focus();
        return;
      }
      phoneError?.classList.add('hidden');
      const bkConsent = (form.elements.namedItem('consent') as HTMLInputElement)?.checked;
      if (!bkConsent) { showBkError('Потрібна згода на обробку персональних даних.'); return; }
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Надсилаємо…'; }

      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch('/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('bad response');
        if (summaryEl && selected) summaryEl.textContent = `${fmtLong(selected)}, ${timeInput.value}`;
        formWrap.classList.add('hidden');
        success.classList.remove('hidden');
        if ((window as any).plausible) (window as any).plausible('booking');
      } catch (err) {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Записатись на консультацію'; }
        const tg = bkError?.dataset.tg || '';
        if (bkError) {
          bkError.innerHTML = `Не вдалося надіслати автоматично. Напишіть нам у <a href="${tg}" target="_blank" rel="noopener" class="underline font-semibold">Telegram</a> або зателефонуйте — ми оформимо запис вручну.`;
          bkError.classList.remove('hidden');
        }
      }
    });

    renderCalendar();
  }
</script>
