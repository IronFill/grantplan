---
import Icon from './Icon.astro';
import { cases } from '../data/cases';
---
<section id="case" class="py-16 md:py-24 border-t border-border/70 bg-surface/30 scroll-mt-20">
  <div class="container-site">
    <div class="reveal max-w-2xl">
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs text-muted">
        <Icon name="badge-check" size={14} class="text-success" /> Реальні кейси · гранти отримано
      </span>
      <h2 class="mt-4 text-3xl sm:text-4xl">Ми не ховаємо роботу за NDA — дивіться самі</h2>
      <p class="mt-4 text-muted text-lg">
        Відкриті кейси клієнтів: кошторис із ринковими цінами, фінмодель на 3 роки, реальні робочі місця та податки для бюджету.
      </p>
    </div>

    <div class="mt-10 grid md:grid-cols-2 gap-6">
      {cases.map((c) => (
        <div class="reveal card-hover rounded-[20px] bg-surface border border-border overflow-hidden flex flex-col">
          <img
            src={c.cover}
            alt={`Слайд презентації: ${c.title}`}
            width="1280" height="800" loading="lazy" decoding="async"
            class="w-full aspect-[16/10] object-cover"
          />
          <div class="p-6 md:p-7 flex flex-col flex-1">
            <h3 class="text-xl font-display font-semibold">{c.title}</h3>
            <p class="mt-2 text-muted flex-1">{c.pitch}</p>
            <div class="mt-5 grid grid-cols-3 gap-2">
              {c.stats.map((s) => (
                <div class="rounded-xl bg-raised border border-border p-3 text-center">
                  <div class="font-display font-bold text-accent text-sm sm:text-base leading-tight">{s.value}</div>
                  <div class="mt-1 text-[0.7rem] text-muted leading-tight">{s.label}</div>
                </div>
              ))}
            </div>
            <a href={`/${c.slug}`} class="btn btn-primary mt-6" data-analytics={`click_case_${c.slug}`}>
              Розібрати кейс детально <Icon name="arrow-right" size={18} />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
