---
import Icon from './Icon.astro';

const plans = [
  {
    name: 'Аудит ідеї',
    price: 'Безкоштовно',
    priceNote: null,
    featured: false,
    features: [
      'Консультація до 20 хв',
      'Оцінка відповідності програмі',
      'Чесний вердикт і план дій',
    ],
    cta: 'Записатись',
    href: '/#lead',
    analytics: 'click_plan_audit',
  },
  {
    name: 'Бізнес-план',
    price: '4 000–6 000 ₴',
    priceNote: 'популярний вибір',
    featured: true,
    features: [
      'Повний план за формою Дії (XLS + Word)',
      'Кошторис з обґрунтуванням цін',
      'Фінмодель і податки',
      '2 раунди правок',
      'Строк 2–3 робочі дні',
    ],
    cta: 'Замовити план',
    href: '/#lead',
    analytics: 'click_plan_plan',
  },
  {
    name: '«Під ключ»',
    price: '8 000–10 000 ₴',
    priceNote: null,
    featured: false,
    features: [
      'Все з тарифу «Бізнес-план»',
      'Презентація для співбесіди',
      'Супровід подання через Дію',
      'Репетиція співбесіди',
      'Підтримка до рішення',
    ],
    cta: 'Обрати супровід',
    href: '/#lead',
    analytics: 'click_plan_turnkey',
  },
];
---
<section id="pricing" class="py-16 md:py-24 scroll-mt-20" data-track-view="view_pricing">
  <div class="container-site">
    <div class="reveal max-w-2xl">
      <h2 class="text-3xl sm:text-4xl">Тарифи</h2>
      <p class="mt-3 text-muted text-lg">Прозоро й без прихованих доплат. Оплата частинами.</p>
    </div>

    <div class="mt-10 grid md:grid-cols-3 gap-5 items-stretch">
      {plans.map((p) => (
        <article
          class={`reveal card-hover relative flex flex-col rounded-[16px] p-6 md:p-7 border ${
            p.featured
              ? 'bg-raised border-accent shadow-[0_0_0_1px_var(--color-accent)]'
              : 'bg-surface border-border'
          }`}
        >
          {p.featured && (
            <span class="absolute -top-3 left-6 inline-flex items-center gap-1.5 rounded-full bg-accent text-[#14181C] px-3 py-1 text-xs font-semibold font-display">
              <Icon name="star" size={13} /> Найпопулярніший
            </span>
          )}
          <h3 class="text-xl font-display font-semibold">{p.name}</h3>
          <div class="mt-3 font-display font-extrabold text-2xl sm:text-[1.75rem] text-accent">{p.price}</div>

          <ul class="mt-6 space-y-3 flex-1">
            {p.features.map((f) => (
              <li class="flex items-start gap-2.5 text-[0.95rem]">
                <Icon name="check" size={18} class="text-success shrink-0 mt-0.5" />
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={p.href}
            class={`btn mt-7 w-full ${p.featured ? 'btn-primary' : 'btn-ghost'}`}
            data-analytics={p.analytics}
          >{p.cta}</a>
        </article>
      ))}
    </div>

    <p class="reveal mt-6 text-sm text-muted text-center">
      Доопрацювання плану після відмови — від 2 000 ₴ · Оплата частинами: 50% аванс, 50% після готовності
    </p>
  </div>
</section>

<script>
  // Подія перегляду тарифів (один раз)
  const sec = document.querySelector<HTMLElement>('[data-track-view="view_pricing"]');
  if (sec && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            if ((window as any).plausible) (window as any).plausible('view_pricing');
            io.disconnect();
          }
        });
      },
      { threshold: 0.4 }
    );
    io.observe(sec);
  }
</script>
