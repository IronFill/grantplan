---
import Icon from './Icon.astro';

const steps = [
  {
    n: '01',
    icon: 'shield-check',
    title: 'Аудит (безкоштовно)',
    text: 'До 20 хвилин чесно кажемо: проходить ідея під умови програми чи ні, і що виправити. Якщо шансів немає — не беремо гроші.',
  },
  {
    n: '02',
    icon: 'calculator',
    title: 'Розрахунок',
    text: 'Бізнес-план за формою Дії: кошторис із комерційними пропозиціями, фінмодель на 36 місяців, податки, точка беззбитковості. Кожна цифра має джерело.',
  },
  {
    n: '03',
    icon: 'file-text',
    title: 'Подання',
    text: 'Переносимо у XLS-форму, перевіряємо КВЕДи й поля, супроводжуємо подачу через Дію з вашим підписом.',
  },
  {
    n: '04',
    icon: 'mic',
    title: 'Співбесіда',
    text: 'Репетируємо захист плану: типові питання, ваші відповіді своїми словами. План ви знатимете як власний — бо він і є ваш.',
  },
];
---
<section id="how" class="py-16 md:py-24 border-t border-border/70 bg-surface/30 scroll-mt-20">
  <div class="container-site">
    <div class="reveal max-w-2xl">
      <span class="text-accent font-display font-semibold text-sm">«Метод чистих цифр»</span>
      <h2 class="mt-2 text-3xl sm:text-4xl">Як це працює — 4 кроки</h2>
      <p class="mt-3 text-muted text-lg">Прозорий процес: ви завжди розумієте, що відбувається і чому.</p>
    </div>

    <ol class="mt-12 grid md:grid-cols-4 gap-5 relative">
      {steps.map((s, i) => (
        <li class="reveal relative rounded-[16px] bg-raised border border-border p-6" style={`transition-delay:${i * 60}ms`}>
          <div class="flex items-center justify-between">
            <span class="inline-grid place-items-center w-11 h-11 rounded-xl bg-accent/10 text-accent">
              <Icon name={s.icon} size={22} />
            </span>
            <span class="font-display font-extrabold text-2xl text-border">{s.n}</span>
          </div>
          <h3 class="mt-5 text-lg font-display font-semibold">{s.title}</h3>
          <p class="mt-2.5 text-sm text-muted leading-relaxed">{s.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
