---
import Icon from './Icon.astro';

const bullets = [
  { icon: 'award', text: 'Багаторічний досвід у фінансах і бухгалтерії' },
  { icon: 'calculator', text: 'Перевірка кожної статті кошторису й податків' },
  { icon: 'file-text', text: 'Розрахунок податків і зборів на 36 місяців' },
  { icon: 'handshake', text: 'Волонтерство: підтримка ВПО з працевлаштуванням' },
];
---
<section class="pb-16 md:pb-24 scroll-mt-20">
  <div class="container-site grid lg:grid-cols-[1.2fr_0.8fr] gap-10 lg:gap-14 items-center">
    <!-- Текст -->
    <div class="reveal order-2 lg:order-1">
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-sm text-muted">
        <Icon name="calculator" size={16} class="text-accent" /> Фінансовий партнер
      </span>
      <h2 class="mt-5 text-3xl sm:text-4xl">Хто рахує ваші цифри</h2>
      <p class="mt-5 text-muted text-lg leading-relaxed">
        Фінансову частину кожного плану — кошторис, податкове навантаження та модель на 3 роки — веде окрема фахівчиня з багаторічним досвідом бухгалтерського й фінансового супроводу бізнесу. Цифри мають витримати перевірку банківського оцінювача, тож рахує їх професійний фінансист, а не юрист. Поза роботою — активна волонтерка: допомагає внутрішньо переміщеним особам із фінансовою грамотністю та працевлаштуванням.
      </p>
      <ul class="mt-7 space-y-3">
        {bullets.map((b) => (
          <li class="flex items-center gap-3">
            <span class="inline-grid place-items-center w-10 h-10 rounded-xl bg-accent/10 text-accent shrink-0">
              <Icon name={b.icon} size={20} />
            </span>
            <span class="font-medium">{b.text}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Фото фінансиста -->
    <div class="reveal order-1 lg:order-2">
      <img
        src="/images/team/finance-v3.webp"
        alt="Фінансистка, яка рахує кошторис і податки в бізнес-плані"
        width="1000" height="1250" loading="lazy" decoding="async"
        class="aspect-[4/5] w-full object-cover rounded-[20px] border border-border"
      />
    </div>
  </div>
</section>
