---
import Icon from './Icon.astro';

const bullets = [
  'Перевірка кожної статті кошторису',
  'Розрахунок податків і зборів на 36 місяців',
  'Контроль відповідності вимогам форми Дії',
];
---
<section class="pb-16 md:pb-24 scroll-mt-20">
  <div class="container-site">
    <div class="reveal rounded-[16px] bg-raised border border-border p-6 md:p-8 flex flex-col md:flex-row gap-6 md:gap-8 md:items-center">
      <span class="inline-grid place-items-center w-14 h-14 rounded-2xl bg-accent/10 text-accent shrink-0">
        <Icon name="calculator" size={28} />
      </span>
      <div>
        <h3 class="text-xl font-display font-semibold">Фінансову частину рахує окремий фахівець</h3>
        <p class="mt-3 text-muted leading-relaxed">
          Кошторис, податкове навантаження та фінансову модель у кожному плані додатково перевіряє партнер-бухгалтер. Це не формальність: цифри мають витримати перевірку банківського оцінювача, тож фінансові розрахунки веде саме фінансист, а не юрист.
        </p>
        <ul class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-muted">
          {bullets.map((b) => (
            <li class="inline-flex items-center gap-2">
              <Icon name="check" size={15} class="text-success shrink-0" /> {b}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
