---
import Icon from './Icon.astro';

// Дві «колони» експертизи. Текст навмисно предметний — демонструє
// знання специфіки програми, а не загальні обіцянки.
const legal = {
  icon: 'scale',
  tag: 'Юридична частина',
  lead:
    'Грант «Власна справа» — це не «заповнити форму». Це юридичне зобов’язання перед державою на три роки. Ми готуємо документи так, щоб вони відповідали чинній редакції правил на дату подання і не створили вам проблем після отримання коштів.',
  points: [
    {
      t: 'Відповідність чинній постанові',
      d: 'Умови програми змінюються (суми, ліміти, вимоги до робочих місць). Перед кожною заявкою звіряємо план із редакцією постанови КМУ та порядком, чинними саме на дату подання, — а не «як було торік».',
    },
    {
      t: 'КВЕД і вид діяльності',
      d: 'Звіряємо заявлену діяльність із зареєстрованими або запланованими кодами КВЕД. Заборонені та непрофільні види відсікаємо ще на безкоштовному аудиті — до того, як ви витратите час і гроші.',
    },
    {
      t: 'Форма та система оподаткування',
      d: 'Обґрунтовуємо вибір ФОП (2 чи 3 група) або ТОВ під вимоги програми й коло ваших контрагентів. Друга група, наприклад, обмежує роботу з юрособами на загальній системі — це враховуємо заздалегідь.',
    },
    {
      t: 'Зобов’язання за договором',
      d: 'Цільове використання коштів, створення робочих місць у строк, сплата податків 3 роки — прописуємо так, щоб ви розуміли межу відповідальності до підпису. Невиконання = повернення гранту.',
    },
  ],
};

const finance = {
  icon: 'calculator',
  tag: 'Фінансова та бухгалтерська частина',
  lead:
    'Банк-партнер і комісія читають не ідею, а цифри. Фінансову модель веде окремий фахівець-бухгалтер: кожна сума має джерело, а розділи плану б’ються між собою до копійки — саме це оцінювач перевіряє першим.',
  points: [
    {
      t: 'Кошторис із підтвердженням',
      d: 'Кожна позиція — з комерційними пропозиціями двох постачальників за ринковими цінами на дату подання. Сума кошторису дорівнює сумі гранту до копійки, без «завищень», які одразу помічає оцінювач.',
    },
    {
      t: 'Фінмодель на 36 місяців',
      d: 'Виручку рахуємо не «зі стелі», а від ємності ринку, цін конкурентів і реалістичної завантаженості. Показуємо точку беззбитковості, потребу в оборотному капіталі та сезонність — комісія цінує тверезість.',
    },
    {
      t: 'Податкове навантаження на 3 роки',
      d: 'Рахуємо єдиний податок, військовий збір і ЄСВ «за себе», а також ЄСВ, ПДФО і ВЗ за найманих працівників. Ви заздалегідь бачите реальні щомісячні платежі та звітність — без сюрпризів після відкриття.',
    },
    {
      t: 'Узгодженість і бюджетний ефект',
      d: 'Цифри в описовій частині, кошторисі та фінмоделі мають збігатися — будь-яку розбіжність усуваємо до подання. Окремо показуємо, скільки податків проєкт поверне бюджету: це посилює заявку.',
    },
  ],
};

const cols = [legal, finance];
---
<section class="py-14 md:py-20 border-t border-border/70 bg-surface/30">
  <div class="container-site">
    <div class="reveal max-w-3xl">
      <span class="text-accent font-display font-semibold text-sm uppercase tracking-wide">Експертиза, а не шаблон</span>
      <h2 class="mt-2 text-3xl sm:text-4xl">Що насправді вирішує долю заявки</h2>
      <p class="mt-4 text-muted text-lg">
        Майже 7 із 10 відмов — не через ідею, а через юридичні й фінансові деталі, які заявник не побачив. Ось на чому тримається кожен наш план.
      </p>
    </div>

    <div class="mt-10 grid lg:grid-cols-2 gap-6 lg:gap-8">
      {cols.map((c) => (
        <div class="reveal rounded-[20px] bg-surface border border-border overflow-hidden">
          <div class="flex items-center gap-3 border-l-2 border-accent bg-raised/60 px-6 py-5">
            <span class="inline-grid place-items-center w-11 h-11 rounded-xl bg-accent/10 text-accent shrink-0">
              <Icon name={c.icon} size={22} />
            </span>
            <span class="font-display font-semibold text-lg">{c.tag}</span>
          </div>
          <div class="p-6 md:p-7">
            <p class="text-muted leading-relaxed">{c.lead}</p>
            <ul class="mt-6 divide-y divide-border/70">
              {c.points.map((p) => (
                <li class="py-4 first:pt-0 last:pb-0">
                  <div class="flex items-start gap-3">
                    <Icon name="check-circle" size={18} class="text-success shrink-0 mt-1" />
                    <div>
                      <div class="font-medium">{p.t}</div>
                      <p class="mt-1 text-sm text-muted leading-relaxed">{p.d}</p>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <p class="reveal mt-8 text-sm text-muted max-w-3xl">
      Саме тому над планом працюють двоє: юрист відповідає за відповідність вимогам і захист, фінансист — за цифри, що витримують перевірку банку. Один підрядник замість «універсала», який знає все потроху.
    </p>
  </div>
</section>
