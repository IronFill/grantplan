---
import Icon from './Icon.astro';

// Блок ПРИХОВАНИЙ. Увімкнути — прибрати data-hidden="true" нижче
// та підставити реальні відгуки. Фейкові відгуки НЕ додавати.
const reviews = [
  { name: '', business: '', text: '', rating: 5 },
  { name: '', business: '', text: '', rating: 5 },
  { name: '', business: '', text: '', rating: 5 },
];
---
<section data-hidden="true" class="py-16 md:py-24 border-t border-border/70">
  <div class="container-site">
    <div class="max-w-2xl">
      <h2 class="text-3xl sm:text-4xl">Що кажуть клієнти</h2>
    </div>
    <div class="mt-10 grid md:grid-cols-3 gap-5">
      {reviews.map((r) => (
        <figure class="rounded-[16px] bg-surface border border-border p-6">
          <Icon name="quote" size={28} class="text-accent/40" />
          <blockquote class="mt-3 text-muted">{r.text}</blockquote>
          <figcaption class="mt-5 flex items-center justify-between">
            <div>
              <div class="font-semibold">{r.name}</div>
              <div class="text-sm text-muted">{r.business}</div>
            </div>
            <div class="flex gap-0.5 text-accent">
              {Array.from({ length: r.rating }).map(() => <Icon name="star" size={14} />)}
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
