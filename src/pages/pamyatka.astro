---
// ВНУТРІШНЯ ПАМ'ЯТКА (не публічна): noindex, не в навігації/сайтмапі,
// закрита в robots.txt. Робочий інструмент для консультацій.
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { rejections } from '../data/rejections';
import { site } from '../data/site';

const anketa = [
  { blk: 'А · Заявник', qs: [
    'ПІБ, вік, область реєстрації та фактичного проживання.',
    'Статус: ветеран / ВПО / діюча ФОП (група, КВЕДи) / фізособа без ФОП.',
    'Чи отримували раніше гранти єРобота? Чи є прострочені кредити, банкрутство?',
    'Досвід у сфері майбутнього бізнесу: роки, посади, навички, сертифікати.',
  ]},
  { blk: 'Б · Ідея та ринок', qs: [
    'Опишіть бізнес одним реченням. Які саме товари/послуги?',
    'Яку проблему клієнтів це вирішує? Чому саме ця ідея?',
    'Хто ваш клієнт (вік, стать, дохід, район/місто)?',
    'Конкуренти у вашому місті: хто, які ціни, чим будете кращі?',
  ]},
  { blk: 'В · Гроші', qs: [
    'Скільки коштів потрібно всього? Перелік закупівель (обладнання, моделі, сировина) з цінами й посиланнями на прайси.',
    'Скільки власних коштів готові додати?',
    'Ціни на ваші товари/послуги. Середній чек.',
    'Реалістична кількість клієнтів/продажів: перші 3 місяці та через рік.',
    'Постійні витрати на місяць: оренда, комуналка, зарплати, сировина, реклама.',
  ]},
  { blk: 'Г · Організація', qs: [
    'Приміщення: власне чи оренда (де, скільки грн/міс)?',
    'Скільки працівників наймете? Посади, зарплати.',
    'Хто вестиме бухгалтерію та податки?',
    'Коли плануєте запуск після отримання коштів?',
  ]},
  { blk: 'Д · Ризики та зобов’язання', qs: [
    'Що може піти не так? План «Б»?',
    'Чи є сезонність?',
    'Чи готові офіційно працювати мінімум 3 роки, створити робочі місця та платити податки? (Якщо ні — грант доведеться повертати.)',
  ]},
];

const objections = [
  { q: '«Ви гарантуєте грант?»', a: 'Ні, і ніхто не може — рішення ухвалює служба зайнятості. Гарантую якість документів і чесну оцінку шансів до оплати. Хто «гарантує» — бреше або зникне з грошима.' },
  { q: '«Чому так дорого? У інших дешевше»', a: 'Прозорий прайс від 4 000 ₴ проти агентських 15–25 тис. Я юрист: договір, відповідальність, локальна специфіка. 70% відмов — це втрачені місяці, а не лише гроші.' },
  { q: '«Я сам можу заповнити форму»', a: 'Можете. Але 70% відмов — саме через самостійні плани: цифри не сходяться, кошторис не обґрунтований. Аудит безкоштовний — приходьте, чесно скажу, чи потрібен я вам.' },
  { q: '«Я подумаю»', a: 'Добре. Врахуйте тайминг: поточна редакція приймає до 1 серпня, далі оновлення. Надішлю клієнтський пакет, щоб було з чим звіритись.' },
];

const scaleRows = [
  'Без робочих місць — до 100 000 ₴',
  '1 місце — до 200 000 ₴ (Харківщина — до 300 000 ₴)',
  '2+ місця — до 350 000 ₴ (Харківщина — до 500 000 ₴)',
  'Молодь 18–25 — до 200 000 ₴ без робочих місць',
  'Ветерани — до 1 000 000 ₴ (реалізація 3/5/7 років)',
  'Родини загиблих/зниклих — до 1 000 000 ₴ при 4 місцях',
  'Повторний грант — доступний з 2026',
];
---
<Layout title="Пам'ятка консультанта — ГрантПлан (внутрішнє)" path="/pamyatka" noindex={true}>
  <div class="pt-14 pb-24">
    <div class="container-site max-w-4xl">
      <div class="rounded-[16px] bg-accent/10 border border-accent/40 px-5 py-3 text-sm text-muted mb-8">
        <Icon name="shield-alert" size={16} class="text-accent inline" /> Внутрішній документ — не для публікації. Робоча пам’ятка для консультацій.
      </div>

      <h1 class="text-3xl sm:text-4xl">Пам’ятка консультанта</h1>
      <p class="mt-2 text-muted">Шпаргалка на дзвінок і супровід клієнта. Оновлення програми — ревізія у вересні 2026.</p>

      <!-- 1. Програма коротко -->
      <section class="mt-10">
        <h2 class="text-2xl">1. Програма коротко</h2>
        <div class="mt-4 grid md:grid-cols-2 gap-4">
          <div class="rounded-[16px] bg-surface border border-border p-5">
            <h3 class="font-display font-semibold">Суми (прив’язані до робочих місць)</h3>
            <ul class="mt-3 space-y-1.5 text-sm text-muted">
              {scaleRows.map((r) => <li class="flex gap-2"><Icon name="check" size={15} class="text-accent shrink-0 mt-0.5" />{r}</li>)}
            </ul>
          </div>
          <div class="rounded-[16px] bg-surface border border-border p-5 space-y-3 text-sm text-muted">
            <div><span class="text-ink font-semibold">Тайминг:</span> поточна редакція — до 1 серпня 2026; оновлення з 1 вересня (до 500 тис на старт / до 2,5 млн на масштабування). У серпні перечитати постанову.</div>
            <div><span class="text-ink font-semibold">Процедура:</span> Дія → XLS-план → КЕП → перевірка Ощадбанку (кредитна історія) → співбесіда в центрі зайнятості → рішення 10–15 днів → спецрахунок в Ощадбанку.</div>
            <div><span class="text-ink font-semibold">Вимоги:</span> 18+, громадянство, чиста кредитна історія (прострочки &gt;30 днів = відмова), без банкрутства.</div>
            <div><span class="text-ink font-semibold">Зобов’язання:</span> цільове використання, робочі місця у строк, податки 3 роки. Невиконання → повернення (повне/пропорційне).</div>
            <div><span class="text-ink font-semibold">Банки:</span> Ощадбанк (основний), ПриватБанк, Сенс Банк.</div>
            <div><span class="text-ink font-semibold">Суміжні (апсейл):</span> переробні до 8 млн (включає БпЛА), фонд «Варто», сади/теплиці.</div>
          </div>
        </div>
      </section>

      <!-- 2. Перший дзвінок -->
      <section class="mt-10">
        <h2 class="text-2xl">2. Перший дзвінок: тон і правила</h2>
        <div class="mt-4 rounded-[16px] bg-surface border border-border p-5 sm:p-6 space-y-2.5 text-[0.95rem] text-muted">
          <p><span class="text-ink font-medium">Хто дзвонить:</span> людина з надією + недовірою (ринок «допомоги з грантами» зіпсований інфоциганами). Перша розмова — це діагностика і зняття недовіри, а не продаж. Мета: щоб поклав трубку з думкою «цей розбирається і не втирає».</p>
          <p><span class="text-ink font-medium">Реакція:</span> відповідати до 3-го гудка; пропустив — передзвонити протягом години. Не консультувати на бігу: «Зараз не можу говорити предметно — наберу о 18:00» → передзвонити хвилина в хвилину (це і є демонстрація надійності).</p>
          <p><span class="text-ink font-medium">Мова:</span> починати українською, далі дзеркалити мову клієнта.</p>
          <p><span class="text-ink font-medium">Тон:</span> спокійний експерт, не продавець. Говорити повільніше, тримати паузи після питань, ім’я — 2–3 рази за розмову. Слухати 60/40 на користь клієнта. Записувати: ім’я, ідея, місто, статус, суми, сумніви.</p>
        </div>
      </section>

      <!-- 3. Структура консультації -->
      <section class="mt-10">
        <h2 class="text-2xl">3. Структура безкоштовної консультації (15 хв)</h2>
        <ol class="mt-4 space-y-3">
          <li class="rounded-[16px] bg-surface border border-border p-5 text-[0.95rem]">
            <span class="text-accent font-display font-semibold">Рамка на старті: </span>
            <span class="text-muted">«Дивіться, як побудуємо розмову: я поставлю кілька питань про ідею і вашу ситуацію (~10 хв), і після цього чесно скажу — проходить ваша ідея під умови програми чи ні, і що робити далі. Домовились?»</span>
          </li>
          <li class="rounded-[16px] bg-surface border border-border p-5 text-[0.95rem] text-muted"><span class="text-ink font-medium">Діагностика:</span> ключові питання анкети (статус, кредитна історія, ідея, робочі місця, готовність до зобов’язань).</li>
          <li class="rounded-[16px] bg-surface border border-border p-5 text-[0.95rem] text-muted"><span class="text-ink font-medium">Чесний вердикт:</span> проходить / не проходить + що виправити. Якщо не проходить — сказати одразу, не брати в роботу.</li>
          <li class="rounded-[16px] bg-surface border border-border p-5 text-[0.95rem] text-muted"><span class="text-ink font-medium">Наступний крок:</span> надіслати клієнтський пакет — умови + перелік документів + анкета.</li>
        </ol>
      </section>

      <!-- 4. Анкета -->
      <section class="mt-10">
        <h2 class="text-2xl">4. Анкета клієнта (20 питань, ~30 хв)</h2>
        <div class="mt-4 space-y-4">
          {anketa.map((b) => (
            <div class="rounded-[16px] bg-surface border border-border p-5">
              <h3 class="font-display font-semibold text-accent">{b.blk}</h3>
              <ul class="mt-2 space-y-1.5 text-[0.95rem] text-muted list-disc pl-5">
                {b.qs.map((q) => <li>{q}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- 5. Причини відмов -->
      <section class="mt-10">
        <h2 class="text-2xl">5. 10 причин відмов (акцент: 1, 2, 6)</h2>
        <div class="mt-4 grid sm:grid-cols-2 gap-3">
          {rejections.map((r) => (
            <div class="rounded-[14px] bg-surface border border-border p-4 text-sm">
              <div class="font-display font-semibold"><span class="text-accent">{r.n}.</span> {r.title}</div>
              <div class="mt-1 text-muted">{r.avoid}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- 6. Заперечення -->
      <section class="mt-10">
        <h2 class="text-2xl">6. Відповіді на заперечення</h2>
        <div class="mt-4 space-y-3">
          {objections.map((o) => (
            <div class="rounded-[16px] bg-surface border border-border p-5">
              <div class="font-display font-semibold">{o.q}</div>
              <div class="mt-1.5 text-[0.95rem] text-muted">{o.a}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- 7. Тарифи -->
      <section class="mt-10">
        <h2 class="text-2xl">7. Тарифи (нагадування)</h2>
        <div class="mt-4 rounded-[16px] bg-surface border border-border p-5 text-[0.95rem] text-muted space-y-1.5">
          <div>Аудит ідеї — безкоштовно (до 20 хв).</div>
          <div>Бізнес-план — 4 000–6 000 ₴ · строк 2–3 дні · 2 раунди правок.</div>
          <div>«Під ключ» — 8 000–10 000 ₴ (+ презентація, супровід подання, репетиція співбесіди).</div>
          <div>Доопрацювання після відмови — від 2 000 ₴ · Оплата: 50% аванс, 50% після готовності.</div>
          <div class="pt-2 text-ink">Перші 2–3 замовлення — за нижньою межею тарифу в обмін на розгорнутий відгук і дозвіл на кейс.</div>
        </div>
      </section>

      <p class="mt-10 text-xs text-muted">Пам’ятка · {site.brand}. Внутрішнє використання. Актуальність умов — перевіряти по постанові перед кожним замовленням.</p>
    </div>
  </div>
</Layout>
