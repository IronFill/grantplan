---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import MobileCta from '../../components/MobileCta.astro';
import Icon from '../../components/Icon.astro';
import Method from '../../components/Method.astro';
import ProgramScale from '../../components/ProgramScale.astro';
import Pricing from '../../components/Pricing.astro';
import CaseTeaser from '../../components/CaseTeaser.astro';
import HonestyBlock from '../../components/HonestyBlock.astro';
import Faq from '../../components/Faq.astro';
import LeadForm from '../../components/LeadForm.astro';
import { audiences } from '../../data/audiences';
import { faq } from '../../data/faq';

export function getStaticPaths() {
  return audiences.map((a) => ({ params: { slug: a.slug }, props: { a } }));
}

const { a } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Layout title={a.metaTitle} description={a.metaDescription} path={`/grant/${a.slug}`} schema={[faqSchema]}>
  <SiteHeader slot="header" />

  <!-- Hero -->
  <section class="relative overflow-hidden pt-28 md:pt-36 pb-16 md:pb-24">
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.04]"
      style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2228%22 height=%2228%22 viewBox=%220 0 28 28%22><path d=%22M0 14h28M14 0v28%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[720px] h-[420px] rounded-full blur-[120px] opacity-20"
      style="background: radial-gradient(circle, #D97E3D, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="container-site relative grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-10 items-center">
      <div class="reveal">
        <a href="/" class="inline-flex items-center gap-2 text-muted hover:text-ink text-sm mb-6">← На головну</a>
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-sm text-muted">
            <span class="w-2 h-2 rounded-full bg-success"></span>
            {a.badge}
          </span>
        </div>
        <h1 class="mt-6 text-[2.1rem] leading-[1.08] sm:text-5xl lg:text-[3.2rem] font-extrabold">
          {a.h1a}<span class="text-accent-gradient">{a.h1accent}</span>{a.h1b}
        </h1>
        <p class="mt-6 text-lg text-muted max-w-xl">{a.lead}</p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="#lead" class="btn btn-primary" data-analytics="click_cta_audience">Безкоштовний експрес-аудит ідеї</a>
          <a href="/case-bpla" class="btn btn-ghost">Подивитись приклад плану</a>
        </div>

        <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm text-muted">
          <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> Чесна оцінка шансів до оплати</li>
          <li class="inline-flex items-center gap-2"><Icon name="check" size={16} class="text-success" /> Форма Дії за 2–3 дні</li>
        </ul>
      </div>

      <!-- Картка ліміту -->
      <div class="reveal hidden lg:block">
        <div class="glass-card rounded-[20px] p-8 text-center">
          <div class="text-sm text-muted">Орієнтовний ліміт</div>
          <div class="mt-2 font-display font-extrabold text-5xl text-accent">{a.limitValue}</div>
          <div class="mt-3 text-sm text-muted">{a.limitNote}</div>
          <div class="mt-6 pt-6 border-t border-border grid grid-cols-2 gap-4 text-left">
            <div>
              <div class="font-display font-extrabold text-xl">2–3 дні</div>
              <div class="text-xs text-muted mt-1">строк плану</div>
            </div>
            <div>
              <div class="font-display font-extrabold text-xl">×2</div>
              <div class="text-xs text-muted mt-1">раунди правок</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Чому саме для цієї аудиторії -->
  <section class="py-16 md:py-24 border-t border-border/70 bg-surface/30">
    <div class="container-site">
      <div class="grid md:grid-cols-3 gap-5">
        {a.points.map((p) => (
          <article class="reveal rounded-[16px] bg-surface border border-border p-6">
            <span class="inline-grid place-items-center w-11 h-11 rounded-xl bg-accent/10 text-accent">
              <Icon name="check-circle" size={22} />
            </span>
            <h3 class="mt-5 text-lg font-display font-semibold">{p.title}</h3>
            <p class="mt-2.5 text-muted text-[0.95rem]">{p.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Method />
  <ProgramScale />
  <Pricing />
  <CaseTeaser />
  <HonestyBlock />
  <Faq />
  <LeadForm />

  <SiteFooter slot="footer" />
  <MobileCta />
</Layout>
