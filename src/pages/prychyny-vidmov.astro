---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileCta from '../components/MobileCta.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
import { rejections } from '../data/rejections';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: '10 причин, за якими відмовляють у гранті «Власна справа»',
  author: { '@type': 'Organization', name: 'ГрантПлан' },
  about: 'Причини відмов у програмі «Власна справа» (єРобота) та як їх уникнути',
};
---
<Layout
  title="Чому відмовляють у гранті «Власна справа»: 10 причин і як їх уникнути | ГрантПлан"
  description="Близько 70% заявок на грант «Власна справа» отримують відмову через план і документи, а не через ідею. Розбираємо 10 головних причин відмов і як їх уникнути."
  path="/prychyny-vidmov"
  schema={[schema]}
>
  <SiteHeader slot="header" />

  <!-- Hero -->
  <section class="relative pt-28 md:pt-36 pb-12 md:pb-16 border-b border-border/70">
    <div class="container-site max-w-3xl">
      <a href="/#case" class="inline-flex items-center gap-2 text-muted hover:text-ink text-sm mb-6">← На головну</a>
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs text-muted">
        <Icon name="alert-triangle" size={14} class="text-accent" /> Довідник · причини відмов
      </span>
      <h1 class="mt-4 text-3xl sm:text-5xl">
        Чому відмовляють у гранті <span class="text-accent">«Власна справа»</span>
      </h1>
      <p class="mt-5 text-muted text-lg">
        Близько 70% заявок отримують відмову — і майже завжди причина не в самій ідеї, а в якості бізнес-плану та супровідних документів. Ось 10 напрямів, за якими найчастіше «зрізають» заявки, і як кожного уникнути.
      </p>
    </div>
  </section>

  <!-- Список причин -->
  <section class="py-14 md:py-20">
    <div class="container-site max-w-3xl space-y-4">
      {rejections.map((r) => (
        <article class="reveal rounded-[16px] bg-surface border border-border p-6 md:p-7">
          <div class="flex items-start gap-4">
            <span class="inline-grid place-items-center w-10 h-10 rounded-xl bg-accent/10 text-accent font-display font-extrabold shrink-0">{r.n}</span>
            <div>
              <h2 class="text-xl font-display font-semibold">{r.title}</h2>
              <p class="mt-3 text-muted">
                <span class="text-ink font-medium">Причина: </span>{r.cause}
              </p>
              <p class="mt-2 text-muted flex gap-2">
                <Icon name="check-circle" size={20} class="text-success shrink-0 mt-0.5" />
                <span><span class="text-ink font-medium">Як уникаємо: </span>{r.avoid}</span>
              </p>
            </div>
          </div>
        </article>
      ))}

      <div class="reveal rounded-[16px] bg-raised border border-accent/70 p-6 md:p-7">
        <p class="text-muted">
          <span class="text-ink font-semibold">Головне:</span> напрями 1, 2 і 6 — фінплан, кошторис і співбесіда — відповідають за більшість відмов і водночас найкраще піддаються якісній підготовці. Саме на них ми робимо акцент у кожному плані.
        </p>
      </div>
    </div>
  </section>

  <LeadForm />

  <SiteFooter slot="footer" />
  <MobileCta />
</Layout>
