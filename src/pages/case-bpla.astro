---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileCta from '../components/MobileCta.astro';
import Icon from '../components/Icon.astro';

const facts = [
  { label: 'Проєкт', value: 'Майстерня БпЛА', icon: 'badge-check' },
  { label: 'Ніша', value: 'Виробництво комплектуючих для БпЛА', icon: 'rocket' },
  { label: 'Локація', value: 'Харків', icon: 'map-pin' },
  { label: 'Сума гранту', value: '500 000 ₴', icon: 'wallet' },
];

const estimate = [
  { item: 'Фрезерний верстат з ЧПК (поле 600×900 мм)', sum: 180_300 },
  { item: '3D-принтери FDM, 3 шт', sum: 150_000 },
  { item: 'Термопрес для ламінування карбону', sum: 65_000 },
  { item: 'Витяжка та фільтрація повітря', sum: 25_000 },
  { item: 'Комп’ютер із ПЗ CAD/CAM', sum: 30_000 },
  { item: 'Оснастка, фрези по композитах, інструмент', sum: 24_700 },
  { item: 'Стелажі та складська зона', sum: 25_000 },
];
const estimateTotal = estimate.reduce((a, b) => a + b.sum, 0);
const uah = (n: number) => n.toLocaleString('uk-UA').replace(/,/g, ' ') + ' ₴';

const financials = [
  { label: 'Дохід за перший рік', value: '1,18 млн ₴' },
  { label: 'Дохід за третій рік', value: '2,28 млн ₴' },
  { label: 'Сплачені податки за 3 роки', value: '1,11 млн ₴' },
];

const stages = [
  { n: '1', title: 'Місяці 1–2', text: 'Реєстрація ФОП, оренда приміщення, закупівля обладнання за кошторисом.' },
  { n: '2', title: 'Місяці 2–3', text: 'Монтаж і налагодження ЧПК та принтерів, пусконалагодження, тестові партії.' },
  { n: '3', title: 'Місяці 3–4', text: 'Найм і навчання 2 працівників, вихід на стабільну якість, перші замовлення.' },
  { n: '4', title: 'Місяці 4–6', text: 'Масштабування виробництва, вихід на планові обсяги та точку беззбитковості.' },
];

const checks = [
  'Ринкові ціни з комерційних пропозицій — кожна позиція кошторису підтверджена КП',
  'Цифри сходяться: кошторис = 500 000 ₴, витрати збігаються з фінмоделлю',
  'Консервативний прогноз доходу — без завищених очікувань',
  '2 робочі місця з календарем найму — виконання зобов’язань програми',
  'Податки пораховані на 3 роки — 1,11 млн ₴ надходжень для бюджету',
];

const products = [
  { name: 'Карбонові рами 7"/10"', desc: 'ЧПУ-фрезерування, карбон 2–5 мм', price: '1 200–1 600 ₴' },
  { name: 'Комплекти друкованих деталей', desc: 'Канопи, кріплення АКБ, маунти', price: '200–450 ₴' },
  { name: 'Окремі запчастини', desc: 'Захист моторів, тримачі, ніжки', price: '100–300 ₴' },
  { name: 'Кастом за кресленням', desc: 'Деталі під ТЗ замовника', price: 'від 300 ₴' },
];

const risks = [
  { title: 'Безпекова ситуація та енергетика', text: 'Резервне живлення, страховий запас сировини, мобільність обладнання.' },
  { title: 'Концентрація на кількох клієнтах', text: 'Мінімум 3 якірні B2B-договори + постійний ритейл-канал.' },
  { title: 'Цінова конкуренція', text: 'Захист через швидкість, кастом і ремонтопридатність.' },
  { title: 'Кадри', text: 'Навчання працівника, документовані техпроцеси.' },
];
---
<Layout
  title="Кейс: бізнес-план майстерні комплектуючих для БпЛА, який отримав грант 500 000 грн | ГрантПлан"
  description="Реальний кейс гранту «Власна справа»: кошторис із ринковими цінами, фінмодель на 3 роки, 2 робочі місця, 1,11 млн грн податків. План пройшов перевірку — грант отримано."
  path="/case-bpla"
>
  <SiteHeader slot="header" />

  <!-- Hero кейса -->
  <section class="relative pt-28 md:pt-36 pb-12 md:pb-16 border-b border-border/70">
    <div class="container-site">
      <a href="/#case" class="inline-flex items-center gap-2 text-muted hover:text-ink text-sm mb-6">
        ← На головну
      </a>
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs text-muted">
        <Icon name="badge-check" size={14} class="text-success" /> Реальний кейс · грант отримано
      </span>
      <h1 class="mt-4 text-3xl sm:text-5xl max-w-3xl">
        Бізнес-план майстерні комплектуючих для дронів на <span class="text-accent">500 000 ₴</span>
      </h1>
      <p class="mt-5 text-muted text-lg max-w-2xl">
        За цим планом заявку подано через Дію, перевірку банку та співбесіду пройдено — грант отримано. Розбираємо, як він побудований.
      </p>
    </div>
  </section>

  <!-- Факти -->
  <section class="py-12 md:py-16">
    <div class="container-site grid grid-cols-2 lg:grid-cols-4 gap-4">
      {facts.map((f) => (
        <div class="reveal rounded-[16px] bg-surface border border-border p-5">
          <Icon name={f.icon} size={22} class="text-accent" />
          <div class="mt-3 text-xs text-muted uppercase tracking-wide">{f.label}</div>
          <div class="mt-1 font-display font-semibold">{f.value}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Слайди презентації -->
  <section class="pb-4">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-4">
        <img src="/case/case-1-cover.png" alt="Слайд презентації: майстерня комплектуючих для БпЛА на грант 500 000 ₴"
          width="1280" height="800" loading="lazy" decoding="async"
          class="reveal w-full rounded-2xl border border-border md:col-span-2" />
        <img src="/case/case-2-koshtorys.png" alt="Слайд презентації: кошторис гранту на 500 000 ₴"
          width="1280" height="800" loading="lazy" decoding="async"
          class="reveal w-full rounded-2xl border border-border" />
        <img src="/case/case-3-finmodel.png" alt="Слайд презентації: фінансова модель на 3 роки"
          width="1280" height="800" loading="lazy" decoding="async"
          class="reveal w-full rounded-2xl border border-border" />
      </div>
    </div>
  </section>

  <!-- Проблема і мета -->
  <section class="py-12 md:py-16 border-t border-border/70 bg-surface/30">
    <div class="container-site grid md:grid-cols-2 gap-6">
      <div class="reveal rounded-[16px] bg-surface border border-border p-7">
        <span class="inline-grid place-items-center w-11 h-11 rounded-xl bg-accent/10 text-accent"><Icon name="alert-triangle" size={22} /></span>
        <h2 class="mt-4 text-2xl">Проблема</h2>
        <p class="mt-3 text-muted">Попит на комплектуючі для БпЛА зростає, але власних потужностей у регіоні бракує. Виробництво потребує стартового обладнання, яке важко профінансувати з нуля.</p>
      </div>
      <div class="reveal rounded-[16px] bg-surface border border-border p-7">
        <span class="inline-grid place-items-center w-11 h-11 rounded-xl bg-success/10 text-success"><Icon name="target" size={22} /></span>
        <h2 class="mt-4 text-2xl">Мета</h2>
        <p class="mt-3 text-muted">Запустити майстерню з ЧПК- та 3D-виробництва, створити 2 офіційні робочі місця та вийти на самоокупність за 6 місяців, використавши грант 500 000 ₴ на обладнання.</p>
      </div>
    </div>
  </section>

  <!-- Продуктова лінійка -->
  <section class="py-12 md:py-16">
    <div class="container-site">
      <h2 class="reveal text-2xl sm:text-3xl">Продуктова лінійка</h2>
      <p class="reveal mt-2 text-muted">Цивільний і навчальний сегмент: FPV, школи операторів, агро- та інспекційні платформи.</p>
      <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {products.map((p) => (
          <div class="reveal rounded-[16px] bg-surface border border-border p-5 flex flex-col">
            <div class="font-display font-semibold flex-1">{p.name}</div>
            <div class="mt-1.5 text-sm text-muted">{p.desc}</div>
            <div class="mt-4 font-display font-extrabold text-accent">{p.price}</div>
          </div>
        ))}
      </div>
      <p class="reveal mt-4 text-sm text-muted flex items-center gap-2">
        <Icon name="wallet" size={16} class="text-accent" /> Середній чек B2B-замовлення (дрібний опт, 10–30 рам): 15 000–25 000 ₴
      </p>
    </div>
  </section>

  <!-- Кошторис -->
  <section class="py-12 md:py-16 border-t border-border/70 bg-surface/30">
    <div class="container-site">
      <h2 class="reveal text-2xl sm:text-3xl">Кошторис обладнання</h2>
      <p class="reveal mt-2 text-muted">Кожна позиція — з комерційною пропозицією постачальника.</p>
      <div class="reveal mt-6 overflow-x-auto rounded-[16px] border border-border">
        <table class="w-full text-left border-collapse min-w-[420px]">
          <thead>
            <tr class="bg-surface text-sm text-muted">
              <th class="py-3.5 px-5 font-medium">Позиція</th>
              <th class="py-3.5 px-5 font-medium text-right">Вартість</th>
            </tr>
          </thead>
          <tbody>
            {estimate.map((row) => (
              <tr class="border-t border-border">
                <td class="py-3.5 px-5">{row.item}</td>
                <td class="py-3.5 px-5 text-right font-medium tabular-nums">{uah(row.sum)}</td>
              </tr>
            ))}
            <tr class="border-t border-border bg-surface/60">
              <td class="py-4 px-5 font-display font-semibold">Разом</td>
              <td class="py-4 px-5 text-right font-display font-extrabold text-accent tabular-nums">{uah(estimateTotal)}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Фінрезультати -->
  <section class="py-12 md:py-16 border-t border-border/70 bg-surface/30">
    <div class="container-site">
      <h2 class="reveal text-2xl sm:text-3xl">Фінансові результати</h2>
      <div class="mt-6 grid sm:grid-cols-3 gap-4">
        {financials.map((f) => (
          <div class="reveal rounded-[16px] bg-raised border border-border p-6 text-center sm:text-left">
            <Icon name="trending-up" size={22} class="text-success mx-auto sm:mx-0" />
            <div class="mt-3 font-display font-extrabold text-2xl sm:text-3xl text-accent">{f.value}</div>
            <div class="mt-1 text-sm text-muted">{f.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Етапи запуску -->
  <section class="py-12 md:py-16">
    <div class="container-site">
      <h2 class="reveal text-2xl sm:text-3xl">Етапи запуску — 6 місяців</h2>
      <div class="mt-6 grid md:grid-cols-4 gap-4">
        {stages.map((s) => (
          <div class="reveal rounded-[16px] bg-surface border border-border p-6">
            <span class="inline-grid place-items-center w-9 h-9 rounded-lg bg-accent text-[#14181C] font-display font-extrabold">{s.n}</span>
            <h3 class="mt-4 font-display font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-muted">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Чому пройшов перевірку -->
  <section class="py-12 md:py-16 border-t border-border/70 bg-surface/30">
    <div class="container-site max-w-3xl">
      <h2 class="reveal text-2xl sm:text-3xl">Чому цей план пройшов перевірку</h2>
      <ul class="mt-6 space-y-3">
        {checks.map((c) => (
          <li class="reveal flex items-start gap-3 rounded-[16px] bg-surface border border-border p-5">
            <Icon name="check-circle" size={22} class="text-success shrink-0 mt-0.5" />
            <span>{c}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Ризики та мінімізація -->
  <section class="py-12 md:py-16">
    <div class="container-site">
      <h2 class="reveal text-2xl sm:text-3xl">Ризики та їх мінімізація</h2>
      <p class="reveal mt-2 text-muted">Комісія цінує реалістичність: у сильному плані ризики не приховані, а прораховані.</p>
      <div class="mt-6 grid sm:grid-cols-2 gap-4">
        {risks.map((r) => (
          <div class="reveal rounded-[16px] bg-surface border border-border p-6">
            <div class="flex items-start gap-3">
              <Icon name="shield-check" size={22} class="text-accent shrink-0 mt-0.5" />
              <div>
                <h3 class="font-display font-semibold">{r.title}</h3>
                <p class="mt-1.5 text-sm text-muted">{r.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 border-t border-border/70">
    <div class="container-site">
      <div class="reveal rounded-[20px] bg-raised border border-accent/70 p-8 md:p-12 text-center relative overflow-hidden">
        <div class="absolute -top-16 left-1/2 -translate-x-1/2 w-72 h-72 rounded-full blur-[100px] opacity-15" style="background:radial-gradient(circle,#FF8A2A,transparent 70%)" aria-hidden="true"></div>
        <h2 class="relative text-2xl sm:text-4xl">Хочу такий план під свою ідею</h2>
        <p class="relative mt-4 text-muted text-lg max-w-xl mx-auto">Почніть із безкоштовного аудиту — чесно скажемо, чи проходить ваша ідея, ще до оплати.</p>
        <a href="/#lead" class="relative btn btn-primary mt-7" data-analytics="click_cta_case">Отримати безкоштовний аудит</a>
      </div>
    </div>
  </section>

  <SiteFooter slot="footer" />
  <MobileCta />
</Layout>
